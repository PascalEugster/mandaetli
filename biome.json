{
	"$schema": "https://biomejs.dev/schemas/2.0.x/schema.json",
	"files": {
		"includes": [
			"**",
			"!src/types/database.ts",
			"!.next",
			"!node_modules",
			"!.planning",
			"!supabase"
		]
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"css": {
		"parser": {
			"cssModules": false,
			"tailwindDirectives": true
		}
	}
}
